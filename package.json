{
  "name": "mermaid-patch",
  "version": "0.1.0",
  "description": "Mermaid plugin for patch diagram diagrams",
  "module": "dist/mermaid-patch.core.mjs",
  "types": "dist/detector.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/mermaid-patch.core.mjs",
      "types": "./dist/detector.d.ts"
    },
    "./*": "./*"
  },
  "keywords": [
    "diagram",
    "mermaid",
    "patch",
    "modular-synth"
  ],
  "license": "MIT",
  "scripts": {
    "compile-grammar": "node scripts/compileGrammar.cjs",
    "prebuild": "node scripts/compileGrammar.cjs",
    "build": "vite build",
    "dev": "vite build --watch",
    "pretest": "node scripts/compileGrammar.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "elkjs": "^0.9.3",
    "nearley": "^2.20.1"
  },
  "devDependencies": {
    "@types/nearley": "^2.11.5",
    "@types/node": "^22.0.0",
    "mermaid": "^11.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "mermaid": "^11"
  },
  "files": [
    "dist"
  ]
}
